# Supabase (legacy — only if still using any Supabase features)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Backend API base URL
VITE_API_URL=http://localhost:4000

# Cloudinary — UNSIGNED uploads only need these two (safe to expose client-side).
# Do NOT put the Cloudinary API key or secret in any VITE_ variable —
# they would be bundled into the public client JS. Keep them in backend/.env.
VITE_CLOUDINARY_CLOUD_NAME=
VITE_CLOUDINARY_UPLOAD_PRESET=
