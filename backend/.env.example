PORT=4000
MONGODB_URI=mongodb://localhost:27017/kebele-zero
JWT_SECRET=change-this-to-a-long-random-secret
JWT_EXPIRES_IN=7d
NODE_ENV=development

# Comma-separated allowed origins for CORS (leave empty to allow all in dev).
# e.g. https://kebele-zero.vercel.app,https://kebelezero.com
CORS_ORIGIN=

# Cloudinary (server-side only — used for deleting images).
# Get these from your Cloudinary dashboard. NEVER expose the secret client-side.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
